{
  "info": {
    "name": "TicketLab API",
    "description": "Complete API collection for TicketLab ticket booking system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ticketlab.com\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Get Events by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/events?category=music",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events"],
              "query": [
                {
                  "key": "category",
                  "value": "music"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Event",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events", "1"]
            }
          }
        },
        {
          "name": "Create Event (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Concert\",\n  \"description\": \"Amazing concert event\",\n  \"location\": \"Concert Hall\",\n  \"category\": \"music\",\n  \"date\": \"15/07/2026\",\n  \"price\": 500000,\n  \"image\": \"/images/concert.jpg\",\n  \"ticketTypes\": [\n    {\n      \"name\": \"VIP\",\n      \"price\": 500000,\n      \"quantity\": 100\n    },\n    {\n      \"name\": \"Standard\",\n      \"price\": 300000,\n      \"quantity\": 200\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Update Event (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Concert Name\",\n  \"description\": \"Updated description\",\n  \"location\": \"New Venue\",\n  \"category\": \"music\",\n  \"date\": \"20/07/2026\",\n  \"price\": 600000\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events", "1"]
            }
          }
        },
        {
          "name": "Delete Event (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/events/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "events", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
